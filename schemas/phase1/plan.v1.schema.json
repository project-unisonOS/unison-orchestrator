{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unisonos.ai/schemas/phase1/plan.v1.schema.json",
  "title": "PlanV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "intent_id", "steps", "tool_calls", "memory_ops", "renderer_directives"],
  "properties": {
    "plan_id": { "type": "string", "minLength": 8 },
    "intent_id": { "type": "string", "minLength": 8 },
    "planner_model": { "type": "string" },
    "policy_summary": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "type", "summary"],
        "properties": {
          "step_id": { "type": "string", "minLength": 4 },
          "type": { "type": "string", "enum": ["respond", "clarify", "tool", "memory"] },
          "summary": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    },
    "tool_calls": { "type": "array", "items": { "$ref": "toolcall.v1.schema.json" }, "default": [] },
    "memory_ops": { "type": "array", "items": { "$ref": "memoryop.v1.schema.json" }, "default": [] },
    "renderer_directives": { "$ref": "renderer_directives.v1.schema.json" },
    "requires_confirmation": { "type": "boolean", "default": false },
    "confirmation_prompt": { "type": "string" }
  }
}
