{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unisonos.ai/schemas/phase1/intent.v1.schema.json",
  "title": "IntentV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent_id", "timestamp", "modality", "raw_input", "normalized_text", "category", "confidence"],
  "properties": {
    "intent_id": { "type": "string", "minLength": 8 },
    "timestamp": { "type": "string", "format": "date-time" },
    "modality": { "type": "string", "enum": ["text", "voice"] },
    "raw_input": { "type": "string" },
    "normalized_text": { "type": "string" },
    "language": { "type": "string", "default": "en" },
    "category": {
      "type": "string",
      "enum": ["qa", "request", "clarification", "control", "actuation", "memory", "unknown"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "value"],
        "properties": {
          "type": { "type": "string" },
          "value": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "default": []
    },
    "requires_clarification": { "type": "boolean", "default": false },
    "clarification_questions": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
